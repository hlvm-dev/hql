{
  "version": 1,
  "name": "agent-e2e-fixture",
  "cases": [
    {
      "name": "list_files agent",
      "match": { "contains": ["list files in src/hlvm/agent"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "list_files", "args": { "path": "src/hlvm/agent" } }
          ]
        },
        {
          "content": "Based on list_files, here are files in src/hlvm/agent: context.ts, llm-integration.ts, orchestrator.ts."
        }
      ]
    },
    {
      "name": "search_code runReActLoop",
      "match": { "contains": ["search for \"runReActLoop\""] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "search_code", "args": { "pattern": "runReActLoop", "path": "src/hlvm/agent" } }
          ]
        },
        {
          "content": "Based on search_code, found occurrences of runReActLoop in src/hlvm/agent/orchestrator.ts."
        }
      ]
    },
    {
      "name": "find_symbol ContextManager",
      "match": { "contains": ["find symbol ContextManager"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "find_symbol", "args": { "name": "ContextManager" } }
          ]
        },
        {
          "content": "Based on find_symbol, ContextManager is declared in src/hlvm/agent/context.ts."
        }
      ]
    },
    {
      "name": "get_structure security",
      "match": { "contains": ["show structure of src/hlvm/agent/security"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "get_structure", "args": { "path": "src/hlvm/agent/security" } }
          ]
        },
        {
          "content": "Based on get_structure, the security directory contains path-sandbox.ts and safety.ts."
        }
      ]
    },
    {
      "name": "path sandbox rejection",
      "match": { "contains": ["read file /etc/passwd"] },
      "steps": [
        {
          "content": "I'm unable to read that file because the path /etc/passwd is outside the workspace boundary. System files like /etc/passwd cannot be accessed from within the workspace."
        }
      ]
    },
    {
      "name": "trace list tools",
      "match": { "contains": ["list files in src/hlvm/agent/tools"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "list_files", "args": { "path": "src/hlvm/agent/tools" } }
          ]
        },
        {
          "content": "Based on list_files, src/hlvm/agent/tools contains file-tools.ts, code-tools.ts, shell-tools.ts, meta-tools.ts."
        }
      ]
    },
    {
      "name": "multi tool list then read",
      "match": { "contains": ["list files and read src/hlvm/agent/context.ts"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "list_files", "args": { "path": "src/hlvm/agent" } },
            { "toolName": "read_file", "args": { "path": "src/hlvm/agent/context.ts" } }
          ]
        },
        {
          "content": "Based on read_file, src/hlvm/agent/context.ts defines the ContextManager for tracking messages."
        }
      ]
    },
    {
      "name": "invalid tool call recovery",
      "match": { "contains": ["simulate invalid tool call then read README"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "read_file", "args": {} }
          ]
        },
        {
          "toolCalls": [
            { "toolName": "read_file", "args": { "path": "README.md" } }
          ]
        },
        {
          "content": "Based on read_file, README.md describes how to use HLVM."
        }
      ]
    },
    {
      "name": "tool error propagation",
      "match": { "contains": ["read missing file ./nope.txt"] },
      "steps": [
        {
          "toolCalls": [
            { "toolName": "read_file", "args": { "path": "./nope.txt" } }
          ]
        },
        {
          "content": "Based on read_file, Error: file not found at ./nope.txt."
        }
      ]
    }
  ]
}
