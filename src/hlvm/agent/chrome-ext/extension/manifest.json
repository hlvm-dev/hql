{
  "manifest_version": 3,
  "name": "HLVM Browser Bridge",
  "version": "1.0.0",
  "description": "Developer tool: connects HLVM CLI to your browser for authenticated automation and testing",
  "minimum_chrome_version": "120",

  "permissions": [
    "tabs",
    "activeTab",
    "nativeMessaging",
    "scripting",
    "webRequest"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "HLVM Browser Bridge"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
