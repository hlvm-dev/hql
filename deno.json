{
  "name": "@hlvm/hql",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./agent": "./src/hlvm/agent/sdk.ts"
  },
  "license": "MIT",
  "imports": {
    "source-map": "npm:source-map@0.6.1",
    "typescript": "npm:typescript@5.3.3",
    "@db/sqlite": "jsr:@db/sqlite@0.12",
    "ai": "npm:ai@^6.0.0",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^3.0.0",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^3.0.0",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.0",
    "ollama-ai-provider-v2": "npm:ollama-ai-provider-v2@^3.0.0",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.12.0",
    "@std/async": "jsr:@std/async@1.0.13",
    "@std/path": "jsr:@std/path@1",
    "@std/semver": "jsr:@std/semver@1",
    "ignore": "npm:ignore@^6.0.0",
    "vlq": "npm:vlq@2.0.4",
    "zod": "npm:zod@^3.25.0",
    "@std/cli": "jsr:@std/cli@1.0.13",
    "@std/media-types": "jsr:@std/media-types@1",
    "@std/encoding": "jsr:@std/encoding@1",
    "tldts": "npm:tldts@7.0.23",
    "react": "npm:react@18",
    "ink": "npm:ink@5",
    "esbuild": "npm:esbuild@^0.17.0",
    "esbuild-wasm": "npm:esbuild-wasm@^0.17.0",
    "jsdom": "npm:jsdom@22.1.0",
    "@mozilla/readability": "npm:@mozilla/readability@0.5.0",
    "lowlight": "npm:lowlight@3",
    "marked": "npm:marked@^17",
    "officeparser": "npm:officeparser@6.0.4",
    "mammoth": "npm:mammoth@1.12.0",
    "xlsx": "npm:xlsx@0.18.5",
    "jszip": "npm:jszip@3.10.1",
    "libreoffice-convert": "npm:libreoffice-convert@1.8.1"
  },
  "lint": {
    "include": ["src/", "tests/", "scripts/"],
    "exclude": ["**/node_modules/**", "**/vendor/**"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },
  "publish": {
    "exclude": [
      ".hlvm-cache/",
      ".build/",
      "dist/",
      "hlvm",
      "hlvm-*",
      "*.log",
      ".DS_Store",
      ".github/",
      ".claude/",
      "!**/*.ts",
      "!**/*.js"
    ]
  },
  "tasks": {
    "test": "deno task test:unit",
    "test:unit": "HLVM_DISABLE_AI_AUTOSTART=1 deno test --parallel --allow-all tests/unit/**/*.test.ts",
    "test:binary": "HLVM_TEST_BINARY=1 deno test --parallel --allow-all tests/binary/**/*.test.ts",
    "test:binary:cli": "HLVM_TEST_BINARY=1 deno test --parallel --allow-all tests/binary/cli/**/*.test.ts",
    "test:binary:stdlib": "HLVM_TEST_BINARY=1 deno test --parallel --allow-all tests/binary/stdlib/**/*.test.ts",
    "test:binary:quick": "deno test --parallel --allow-all tests/binary/**/*.test.ts",
    "test:compat": "deno test --parallel --allow-all tests/binary/compat/**/*.test.ts",
    "test:e2e:examples": "deno run -A scripts/run-local-examples-all.ts",
    "test:integration": "HLVM_DISABLE_AI_AUTOSTART=1 deno test --allow-all tests/integration/**/*.test.ts",
    "test:conformance": "HLVM_DISABLE_AI_AUTOSTART=1 deno test --parallel --allow-all tests/interop/mcp/**/*.test.ts",
    "test:e2e:agent": "deno test --parallel --allow-all tests/e2e/**/*.test.ts",
    "test:e2e": "deno run -A scripts/run-tasks-parallel.ts test:e2e:examples test:e2e:agent",
    "test:all": "deno run -A scripts/run-tasks-parallel.ts test:unit test:binary:quick",
    "test:all:binary": "deno run -A scripts/run-tasks-parallel.ts test:unit test:binary",
    "test:watch": "deno test --parallel --allow-all --watch tests/unit/**/*.test.ts",
    "test:ultimate": "deno run -A scripts/run-tasks-parallel.ts test:unit test:binary test:e2e",
    "test:ultimate:quick": "deno run -A scripts/run-tasks-parallel.ts test:unit test:binary:quick test:e2e",
    "scrape-models": "deno run --allow-net --allow-write --allow-read --allow-env scripts/scrape-ollama-models.ts --output /tmp/ollama_models.json",
    "scrape-models:sync": "deno run --allow-net --allow-write --allow-read --allow-env scripts/scrape-ollama-models.ts --sync",
    "publish-catalog": "deno task scrape-models && gh gist edit b8c5e2a44ec9cb01cbaa010a8953304c /tmp/ollama_models.json",
    "check:platform": "deno run --allow-read scripts/check-platform-abstraction.ts",
    "ssot:check": "deno run --allow-read scripts/ssot-check.ts",
    "check:stdlib:generated": "deno run -A scripts/check-stdlib-generated.ts",
    "check:stdlib:deterministic": "deno run -A scripts/check-stdlib-deterministic.ts",
    "check:prod:p0": "deno task ssot:check && deno task check:stdlib:generated && deno task check:stdlib:deterministic && deno task test:conformance",
    "test:interop": "HLVM_DISABLE_AI_AUTOSTART=1 deno test --allow-all tests/interop/**/*.test.ts",
    "test:ci": "deno task ssot:check && deno task test:unit",
    "build:npm": "deno run -A scripts/build-npm.ts",
    "stdlib:build": "deno run -A scripts/build-stdlib.ts",
    "openapi": "deno run -A scripts/generate-openapi.ts"
  }
}
